{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "panels": [
    {
      "type": "stat",
      "title": "Total Events Audited",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "targets": [
        { "expr": "sum(audit_events_consumed_total)", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [ { "color": "green", "value": null } ] },
          "unit": "short"
        }
      }
    },
    {
      "type": "stat",
      "title": "Duplicates Detected",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "targets": [
        { "expr": "sum(audit_duplicates_detected_total)", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "short"
        }
      }
    },
    {
      "type": "stat",
      "title": "Missing Events (Gap-Inferred)",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "targets": [
        { "expr": "sum(audit_missing_events_total)", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 }
            ]
          },
          "unit": "short"
        }
      }
    },
    {
      "type": "stat",
      "title": "p99 Processing Latency",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "targets": [
        { "expr": "audit_processing_duration_seconds{quantile=\"0.99\"} * 1000", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          },
          "unit": "ms"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Events Consumed per Second (by source)",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "sum by (source) (rate(audit_events_consumed_total[1m]))",
          "legendFormat": "{{source}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      }
    },
    {
      "type": "timeseries",
      "title": "Audit Processing Latency (p50 / p95 / p99)",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 6 },
      "targets": [
        {
          "expr": "audit_processing_duration_seconds{quantile=\"0.5\"} * 1000",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "audit_processing_duration_seconds{quantile=\"0.95\"} * 1000",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "audit_processing_duration_seconds{quantile=\"0.99\"} * 1000",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms" }
      }
    }
  ],
  "refresh": "5s",
  "schemaVersion": 38,
  "tags": ["kafka", "audit"],
  "time": { "from": "now-15m", "to": "now" },
  "title": "Kafka Audit Service",
  "uid": "kafka-audit-001",
  "version": 1
}
